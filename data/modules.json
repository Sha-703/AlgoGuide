        "bonneReponse": 1,
        "explication": "On utilise FIN_SI pour fermer une structure conditionnelle."
      }
    ]
  },
  {
    "id": "tant_que",
    "titre": "Boucle TANT QUE",
    "description": "Répète des instructions tant qu'une condition reste vraie.",
    "notion": "TANT_QUE",
    "difficulte": "intermediaire",
    "algorithme": [
      { "id": 1, "texte": "// Compter les sacs de riz jusqu'à remplir le stock", "type": "commentaire", "indent": 0 },
      { "id": 2, "texte": "stock <- 0", "type": "instruction", "indent": 0 },
      { "id": 3, "texte": "max <- 5", "type": "instruction", "indent": 0 },
      { "id": 4, "texte": "TANT QUE stock < max FAIRE", "type": "boucle", "indent": 0, "trou": true, "reponse": "TANT QUE stock < max FAIRE" },
      { "id": 5, "texte": "stock <- stock + 1", "type": "instruction", "indent": 1 },
      { "id": 6, "texte": "AFFICHER stock", "type": "instruction", "indent": 1 },
      { "id": 7, "texte": "FIN_TANT_QUE", "type": "fin", "indent": 0 },
      { "id": 8, "texte": "AFFICHER \"Stock plein !\"", "type": "instruction", "indent": 0 }
    ],
    "variables": { "stock": 0, "max": 5 },
    "quiz": [
      {
        "id": "q1",
        "enonce": "Combien de fois la boucle s'exécute-t-elle ?",
        "choix": ["4 fois", "5 fois", "6 fois", "Indéfiniment"],
        "bonneReponse": 1,
        "explication": "La boucle s'exécute pour stock = 0, 1, 2, 3, 4, soit 5 fois."
      },
      {
        "id": "q2",
        "enonce": "Quelle valeur a stock après la boucle ?",
        "choix": ["4", "5", "6", "0"],
        "bonneReponse": 1,
        "explication": "Quand stock = 5, la condition stock < 5 devient fausse et on sort de la boucle."
      },
      {
        "id": "q3",
        "enonce": "Que risque-t-il d'arriver si on oublie stock <- stock + 1 ?",
        "choix": ["Rien", "Boucle infinie", "Erreur de syntaxe", "stock = -1"],
        "bonneReponse": 1,
        "explication": "Sans incrémenter stock, la condition reste toujours vraie → boucle infinie !"
      }
    ]
  },
  {

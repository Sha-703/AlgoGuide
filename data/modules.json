    "description": "Apprends à prendre des décisions dans ton algorithme selon une condition.",
    "notion": "SI_SINON",
    "difficulte": "debutant",
    "algorithme": [
      { "id": 1, "texte": "// Vérifier si un élève a réussi son examen", "type": "commentaire", "indent": 0 },
      { "id": 2, "texte": "note <- 14", "type": "instruction", "indent": 0 },
      { "id": 3, "texte": "seuil <- 10", "type": "instruction", "indent": 0 },
      { "id": 4, "texte": "SI note >= seuil ALORS", "type": "condition", "indent": 0, "trou": true, "reponse": "SI note >= seuil ALORS" },
      { "id": 5, "texte": "AFFICHER \"Félicitations, tu as réussi !\"", "type": "instruction", "indent": 1 },
      { "id": 6, "texte": "SINON", "type": "condition", "indent": 0 },
      { "id": 7, "texte": "AFFICHER \"Tu dois retravailler le cours.\"", "type": "instruction", "indent": 1 },
      { "id": 8, "texte": "FIN_SI", "type": "fin", "indent": 0 }
